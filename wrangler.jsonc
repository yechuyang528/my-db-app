{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-db-app",
  "compatibility_date": "2026-05-19",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "my-db-app-db",
      "database_id": "PLACEHOLDER_FILL_LATER"
    }
  ]
}